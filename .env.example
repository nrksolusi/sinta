# Sinta runtime configuration.
#
# Copy this file to .env and adjust for your machine:
#   cp .env.example .env
#
# .env is git-ignored (secrets never enter git); this template holds
# local-development placeholders only. One .env feeds the whole stack:
# the Go server and migrate command (loaded via godotenv), docker-compose
# (Postgres credentials), and the Vite dev server (proxy target + port).

# --- Database ---------------------------------------------------------------
# Primary (writer) connection string. In production this must connect as the
# sinta_app role, not the database owner, so RLS policies apply (ADR-0004).
# A future read replica / shards are additive: DATABASE_READ_URL, etc.
DATABASE_URL=postgres://sinta:sinta_dev@localhost:5432/sinta?sslmode=disable

# Postgres container credentials, consumed by docker-compose.yml.
# Keep these consistent with DATABASE_URL for local development.
POSTGRES_USER=sinta
POSTGRES_PASSWORD=sinta_dev
POSTGRES_DB=sinta

# --- Server -----------------------------------------------------------------
# HTTP listen port for the Go API (cmd/sinta).
PORT=8080

# --- Client (Vite dev) ------------------------------------------------------
# Port for the Vite dev server.
CLIENT_PORT=3000
# The dev proxy target for /v1 is derived from PORT above
# (http://localhost:${PORT}); it is used only by vite.config.ts and is never
# bundled into the browser.

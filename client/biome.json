{
  "$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",
  "files": {
    "includes": [
      "**",
      "!src/routeTree.gen.ts",
      "!src/paraglide",
      "!project.inlang/.meta.json",
      "!src/lib/api-types.ts",
      "!src/components/ui",
      "!src/styles.css",
      "!.output",
      "!.nitro",
      "!.tanstack",
      "!dist"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}

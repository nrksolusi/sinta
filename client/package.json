    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate-i18n": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "machine-translate": "inlang machine translate --project project.inlang"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist-mono": "^5.3.0",

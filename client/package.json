    "@tanstack/react-form": "^1.33.2",
    "@tanstack/react-query": "^5.101.3",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.13.1",
    "sonner": "^2.0.7",

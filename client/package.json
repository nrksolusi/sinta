{
  "name": "sinta",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "generate-api": "openapi-typescript ../server/api/openapi.yaml -o src/lib/api-types.ts",

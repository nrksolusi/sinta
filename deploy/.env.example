# Sinta production environment. Copy to deploy/.env and fill in real values.
# NEVER commit deploy/.env - it is gitignored (see repo .gitignore: .env*).
#
#   cp deploy/.env.example deploy/.env && edit deploy/.env

# --- Database (owner role) --------------------------------------------------
# The database owner. Migrations run as this role; it also sets the app role's
# password. Keep this credential off the app's connection string.
POSTGRES_USER=sinta
POSTGRES_PASSWORD=change-me-owner-password
POSTGRES_DB=sinta

# --- Application role (RLS-constrained) -------------------------------------
# The server connects as sinta_app so RLS policies apply (ADR-0004). This
# password is applied to the role by the setapppw init step and used in the
# server's DATABASE_URL.
SINTA_APP_PASSWORD=change-me-app-password

# --- Server -----------------------------------------------------------------
# Reserved for signing/session hardening. Generate with:
#   openssl rand -base64 48
SESSION_SECRET=change-me-generate-a-long-random-string

# --- HTTPS / domain ---------------------------------------------------------
# The public hostname Caddy serves. Set to a real domain for automatic HTTPS
# via Let's Encrypt (DNS must already point at this VPS). Use ":80" for a
# local no-TLS smoke test.
SINTA_DOMAIN=app.sinta.example

# --- Backups ----------------------------------------------------------------
# Offsite target for the nightly pg_dump. s3://bucket/prefix uploaded via
# aws/rclone if present in the backup image (see deploy/README.md), otherwise
# override the whole command with BACKUP_UPLOAD_CMD.
BACKUP_S3_TARGET=s3://sinta-backups/pg
# BACKUP_UPLOAD_CMD=rclone copyto "$1" "remote:sinta-backups/$(basename $1)"
BACKUP_HOUR=02
BACKUP_RETENTION_DAYS=14
